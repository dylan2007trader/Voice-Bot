# Copy this file to .env and fill in your values.
# Get these from your Vapi dashboard: https://dashboard.vapi.ai

# Your Vapi PRIVATE API key (Dashboard -> Settings -> API Keys).
VAPI_API_KEY=your-vapi-private-key-here

# The ID of the phone number you call FROM (your one caller ID for all calls).
# Run `python -m voicebot numbers` to list your numbers and their IDs.
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id-here

# The number under test. Do not change this — it is the assessment line.
TEST_NUMBER=+18054398008

# LLM that drives the patient. gpt-4o = most natural; gpt-4o-mini = cheaper.
PATIENT_MODEL=gpt-4o
